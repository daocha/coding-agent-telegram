PACKAGE_NAME=coding-agent-telegram
WORKSPACE_ROOT=~/git/
STATE_FILE=./state.json
STATE_BACKUP_FILE=./state.json.bak
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_CHAT_ID=123456
ALLOWED_CHAT_IDS=123456,789012

CODEX_BIN=codex
COPILOT_BIN=copilot
CODEX_APPROVAL_POLICY=never
CODEX_SANDBOX_MODE=workspace-write

MAX_TELEGRAM_MESSAGE_LENGTH=3000
ENABLE_GROUP_CHATS=false
ENABLE_SENSITIVE_DIFF_FILTER=true
DEFAULT_AGENT_PROVIDER=codex
