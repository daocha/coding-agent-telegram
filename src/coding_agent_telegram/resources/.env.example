# UI locale for shared bot messages and command descriptions.
# When this env file is created for the first time from the example, the app
# initializes APP_LOCALE from the system language. You can change it here later.
# Supported values: en, de, fr, ja, ko, nl, th, vi, zh-CN, zh-HK, zh-TW
APP_LOCALE=en

# Package/service label used by local startup scripts.
PACKAGE_NAME=coding-agent-telegram

# Root directory that contains the project folders the bot may work in.
WORKSPACE_ROOT=

# Application log level.
LOG_LEVEL=INFO

# Comma-separated Telegram bot tokens.
TELEGRAM_BOT_TOKENS=

# Comma-separated allowed private chat IDs.
ALLOWED_CHAT_IDS=

# Codex CLI executable name or path.
CODEX_BIN=codex

# Copilot CLI executable name or path.
COPILOT_BIN=copilot

# Optional Codex model override.
CODEX_MODEL=

# Optional Copilot model override.
COPILOT_MODEL=

# Whether Copilot should run in autopilot mode.
COPILOT_AUTOPILOT=true

# Whether Copilot should avoid asking the user interactive questions.
COPILOT_NO_ASK_USER=true

# Whether Copilot may use all tools without an allowlist.
COPILOT_ALLOW_ALL=true

# Whether Copilot may use all tools when allow-all is disabled.
COPILOT_ALLOW_ALL_TOOLS=false

# Comma-separated Copilot tool allowlist.
COPILOT_ALLOW_TOOLS=

# Comma-separated Copilot tool denylist.
COPILOT_DENY_TOOLS=

# Comma-separated list of all Copilot tools exposed to the agent.
COPILOT_AVAILABLE_TOOLS=

# Codex approval policy.
CODEX_APPROVAL_POLICY=never

# Codex sandbox mode.
CODEX_SANDBOX_MODE=workspace-write

# If true, bypass Codex's repo trust check for all projects.
CODEX_SKIP_GIT_REPO_CHECK=false

# If true, expose the /commit command.
ENABLE_COMMIT_COMMAND=false

# Maximum file size, in bytes, loaded as text for snapshot-based diffs.
SNAPSHOT_TEXT_FILE_MAX_BYTES=200000

# Comma-separated path globs to force-include in diffs, even if built-in or user snapshot exclusions would hide them.
# Include globs win when both include and exclude rules match.
# Example: SNAPSHOT_INCLUDE_PATH_GLOBS=.github/*,.profile.test,.profile.prod
SNAPSHOT_INCLUDE_PATH_GLOBS=

# Comma-separated path globs to exclude from diffs in addition to the built-in snapshot exclusions.
# `.*` matches hidden paths, including files inside hidden directories such as .github/workflows/python-publish.yml.
# Example: SNAPSHOT_EXCLUDE_PATH_GLOBS=.*,personal/*,sensitive*.txt
SNAPSHOT_EXCLUDE_PATH_GLOBS=

# Maximum Telegram message length before chunking.
MAX_TELEGRAM_MESSAGE_LENGTH=3000

# Reserved setting; group chats are currently unsupported.
ENABLE_GROUP_CHATS=false

# If true, hide diffs for sensitive-looking file paths.
ENABLE_SENSITIVE_DIFF_FILTER=true

# If true, redact recognized secrets and secret-like blobs from assistant output before sending them to Telegram.
# Strongly recommended: keep this set to true.
ENABLE_SECRET_SCRUB_FILTER=true

# If true, enable Telegram voice-message speech-to-text through local openai-whisper.
# Default: false. Run coding-agent-telegram-stt-install (pip install) or ./install-stt.sh (repo clone) first.
# Estimated local footprint: openai-whisper package ~50 MB, ffmpeg ~50 MB, plus Whisper model downloads.
# Example model cache sizes: tiny ~72 MB, base ~139 MB, large-v3-turbo ~1.5 GB.
ENABLE_OPENAI_WHISPER_SPEECH_TO_TEXT=false

# Whisper model name to use for Telegram voice-message speech-to-text.
# Recommended default: base. `turbo` downloads the large-v3-turbo model (~1.5 GB).
# Models download automatically on first use into ~/.cache/whisper.
# If the selected model is not cached yet, the first voice transcription may take longer.
# With `turbo`, that first call is more likely to hit OPENAI_WHISPER_TIMEOUT_SECONDS before the download finishes.
OPENAI_WHISPER_MODEL=base

# Timeout for a single Whisper transcription call, in seconds.
OPENAI_WHISPER_TIMEOUT_SECONDS=120

# Default agent provider for new sessions: codex or copilot.
DEFAULT_AGENT_PROVIDER=codex

# Hard time limit (seconds) for a single agent run.
# When the subprocess is still running after this many seconds the bot sends
# a timeout message and terminates the agent.
# Set to 0 (the default) to disable the limit entirely — recommended when
# using Copilot, which can legitimately take over an hour for heavy tasks.
# Useful as a safeguard when using Codex for shorter, bounded jobs.
# Example: AGENT_HARD_TIMEOUT_SECONDS=600  (10 minutes)
AGENT_HARD_TIMEOUT_SECONDS=0
